{
    "name": "spellbook",
    "private": true,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "dev": "bunchee --watch",
        "build": "bunchee",
        "start": "node ./dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "oxlint",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "bunchee": "^6.9.4",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "tsdx": "^2.0.0",
        "vitest": "^4.1.2"
    },
    "peerDependencies": {
        "typescript": "^6.0.2"
    }
}
